# 复制为 server/.env 或仓库根目录 .env（load-env 会依次加载 server/.env 与 ../.env）
#
# 本地开发后端端口（pnpm dev / scripts/server-dev.sh 会读；未写时默认 9091）
SERVER_PORT=9091

# --- Supabase（Express 读库；列表接口未配 service role 时走 anon，RLS 可能返回空）---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # Dashboard → Project Settings → API → service_role（仅服务端，勿打进客户端）

# --- Google Gemini（回忆总结优先使用；https://aistudio.google.com/apikey）---
# 勿留空 GEMINI_API_KEY= 行，否则会覆盖仓库根目录 .env 里的同名变量
# GEMINI_API_KEY=
# 也可用：GOOGLE_GENERATIVE_AI_API_KEY=
# 默认 gemini-2.0-flash；可按账号改为 gemini-2.5-flash、gemini-1.5-flash 等
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_TIMEOUT_MS=90000

# --- 局域网 OpenAI 兼容服务（如 Jetson 上 serve_qwen_vl.py；Gemini 失败或未配置时回退）---
#
# LOCAL_LLM_BASE_URL 须带 /v1 结尾，或只写 host:port（会自动补 /v1）
LOCAL_LLM_BASE_URL=http://192.168.1.105:8000/v1
LOCAL_LLM_MODEL=Qwen/Qwen-2.5-7B-VL
# LOCAL_LLM_API_KEY=
# LOCAL_LLM_TIMEOUT_MS=180000

# 若未设置 LOCAL_LLM_*，仍可读下列旧变量名（二选一即可）
# VLLM_BASE_URL=http://192.168.1.105:8000/v1
# VLLM_MODEL=Qwen/Qwen-2.5-7B-VL
