# ========================================
# Voxora 家庭回忆录 - 环境变量配置示例
# ========================================
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填入实际值（不要提交 .env 到 Git）
# 3. 参考 SUPABASE_SETUP.md 获取配置凭证
# ========================================

# ========================================
# 前端环境变量（EXPO_PUBLIC_ 前缀）
# ========================================

# 后端 API 基础 URL（必需）
# 本地开发：http://localhost:9091
# 生产环境：https://your-domain.com
EXPO_PUBLIC_BACKEND_BASE_URL=http://localhost:9091
#
# Coze 空间从 GitHub 部署时：一般无需手填此项，平台会通过 coze dev / .cozeproj 脚本注入
# EXPO_PUBLIC_BACKEND_BASE_URL（及 EXPO_PACKAGER_PROXY_URL）。客户端会优先使用该地址。

# API 基础 URL（可选）
# 如果与 BACKEND_BASE_URL 不同，可以单独配置
EXPO_PUBLIC_API_BASE=

# Coze 项目 ID（可选）
# 用于构建应用的 slug 和 package name
EXPO_PUBLIC_COZE_PROJECT_ID=

# Coze 项目名称（可选）
# 应用的显示名称
EXPO_PUBLIC_COZE_PROJECT_NAME=Voxora

# ========================================
# 后端环境变量
# ========================================

# 后端服务端口（默认 9091）
PORT=9091

# 环境类型
NODE_ENV=development

# ========================================
# Supabase 数据库配置（必需）
# ========================================

# Supabase 项目 URL（必需）
# 获取方式：Supabase Dashboard → Settings → API → Project URL
# 格式：https://xxx.supabase.co
COZE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 匿名密钥（必需）
# 获取方式：Supabase Dashboard → Settings → API → anon public key
# 这是公开密钥，可以用于客户端
COZE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase 服务角色密钥（可选，用于管理操作）
# 获取方式：Supabase Dashboard → Settings → API → service_role secret
# ⚠️ 警告：此密钥具有管理员权限，可以绕过所有安全限制，请勿泄露！
# 仅在服务端需要执行管理操作时配置
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ========================================
# 数据库连接（可选，用于 init-demo-data.js）
# ========================================

# PostgreSQL 数据库连接字符串（方式 1）
# 获取方式：Supabase Dashboard → Settings → Database → Connection string → URI
# 格式：postgresql://postgres:[password]@db.xxx.supabase.co:5432/postgres
# DATABASE_URL=postgresql://postgres:your-password@db.xxx.supabase.co:5432/postgres

# PostgreSQL 连接 URL（方式 2，与 DATABASE_URL 作用相同）
# POSTGRES_URL=postgresql://postgres:your-password@db.xxx.supabase.co:5432/postgres

# Supabase 数据库密码（方式 3，脚本会自动从 COZE_SUPABASE_URL 提取并构建连接）
# SUPABASE_DB_PASSWORD=your-database-password

# Postgres 密码（备用，与 SUPABASE_DB_PASSWORD 作用相同）
# POSTGRES_PASSWORD=your-database-password

# ========================================
# 对象存储配置（用于文件上传）
# ========================================

# S3 兼容对象存储端点（必需）
# 由系统自动注入，本地部署需要配置
COZE_BUCKET_ENDPOINT_URL=https://your-storage-endpoint.com

# S3 存储桶名称（必需）
# 由系统自动注入，本地部署需要配置
COZE_BUCKET_NAME=your-bucket-name

# S3 区域（已硬编码为 cn-beijing）
# STORAGE_REGION=cn-beijing

# ========================================
# 开发环境变量（备用）
# ========================================

# Coze 项目名称（备用，与 EXPO_PUBLIC_COZE_PROJECT_NAME 作用相同）
# COZE_PROJECT_NAME=Voxora

# Coze 项目 ID（备用，与 EXPO_PUBLIC_COZE_PROJECT_ID 作用相同）
# COZE_PROJECT_ID=

# ========================================
# 环境变量优先级说明
# ========================================

# 前端配置优先级：
# - 应用名称：COZE_PROJECT_NAME > EXPO_PUBLIC_COZE_PROJECT_NAME > '应用'
# - 项目 ID：COZE_PROJECT_ID > EXPO_PUBLIC_COZE_PROJECT_ID
#
# 数据库连接优先级（init-demo-data.js）：
# - DATABASE_URL > POSTGRES_URL > (COZE_SUPABASE_URL + SUPABASE_DB_PASSWORD)
#
# Supabase 客户端初始化：
# - 使用 COZE_SUPABASE_URL + COZE_SUPABASE_ANON_KEY
# - 管理操作可使用 COZE_SUPABASE_SERVICE_ROLE_KEY

# ========================================
# 必需配置（最小化部署）
# ========================================

# 如果只是运行应用，最少需要配置以下变量：
# 1. EXPO_PUBLIC_BACKEND_BASE_URL（后端 API 地址）
# 2. COZE_SUPABASE_URL（Supabase 项目 URL）
# 3. COZE_SUPABASE_ANON_KEY（Supabase 匿名密钥）
# 4. COZE_BUCKET_ENDPOINT_URL（对象存储端点）
# 5. COZE_BUCKET_NAME（对象存储桶名称）

# ========================================
# 安全提示
# ========================================

# ⚠️ 不要将 .env 文件提交到 Git
# ⚠️ 不要分享 COZE_SUPABASE_SERVICE_ROLE_KEY
# ⚠️ 不要分享 DATABASE_URL 中的密码
# ✅ 已将 .env 添加到 .gitignore

# ========================================
# 如何获取配置凭证
# ========================================

# 1. 登录 https://supabase.com/dashboard
# 2. 创建新项目或选择现有项目
# 3. 进入 Settings → API
# 4. 复制以下内容：
#    - Project URL → 填入 COZE_SUPABASE_URL
#    - anon public key → 填入 COZE_SUPABASE_ANON_KEY
#    - service_role secret → 填入 COZE_SUPABASE_SERVICE_ROLE_KEY（可选）
# 5. 进入 Settings → Database → Connection string → URI
# 6. 复制连接字符串 → 填入 DATABASE_URL 或提取密码填入 SUPABASE_DB_PASSWORD

# 详细步骤请参考 SUPABASE_SETUP.md
