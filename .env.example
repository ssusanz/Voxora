# 本地部署环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ========================================
# Supabase 配置（必需）
# ========================================

# Supabase 项目 URL
# 获取方式：Supabase Dashboard → Settings → API → Project URL
# 格式：https://xxx.supabase.co
COZE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 匿名密钥
# 获取方式：Supabase Dashboard → Settings → API → anon public key
COZE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase 服务角色密钥（可选，用于管理操作）
# 获取方式：Supabase Dashboard → Settings → API → service_role secret
# ⚠️ 警告：此密钥具有管理员权限，请勿泄露！
# COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ========================================
# 数据库连接（可选，用于 init-demo-data.js）
# ========================================

# PostgreSQL 数据库连接字符串
# 获取方式：Supabase Dashboard → Settings → Database → Connection string → URI
# 格式：postgresql://postgres:[password]@db.xxx.supabase.co:5432/postgres
# DATABASE_URL=postgresql://postgres:your-password@db.xxx.supabase.co:5432/postgres

# 或者使用以下方式配置（脚本会自动从 COZE_SUPABASE_URL 提取）
SUPABASE_DB_PASSWORD=your-database-password

# ========================================
# 应用配置（可选）
# ========================================

# 应用运行端口
PORT=9091

# 环境类型
NODE_ENV=development

# ========================================
# 对象存储配置（如果使用）
# ========================================

# S3 兼容对象存储端点
# STORAGE_ENDPOINT=https://your-storage-endpoint.com

# S3 访问密钥
# STORAGE_ACCESS_KEY_ID=your-access-key

# S3 密钥
# STORAGE_SECRET_ACCESS_KEY=your-secret-key

# S3 存储桶名称
# STORAGE_BUCKET_NAME=your-bucket-name

# S3 区域
# STORAGE_REGION=us-east-1

# ========================================
# 说明
# ========================================

# 1. 必需配置：
#    - COZE_SUPABASE_URL（Supabase 项目 URL）
#    - COZE_SUPABASE_ANON_KEY（Supabase 匿名密钥）
#
# 2. 可选配置：
#    - COZE_SUPABASE_SERVICE_ROLE_KEY（用于管理操作）
#    - DATABASE_URL（用于演示数据初始化脚本）
#
# 3. 获取步骤：
#    a. 登录 https://supabase.com/dashboard
#    b. 创建新项目或选择现有项目
#    c. 进入 Settings → API
#    d. 复制 Project URL 和 anon public key
#    e. 将值填入上方对应的变量
#
# 4. 使用方法：
#    cp .env.example .env
#    编辑 .env 文件，填入实际值
#    启动应用
#
# 5. 安全提示：
#    - ⚠️ 不要将 .env 文件提交到 Git
#    - ⚠️ 不要分享 COZE_SUPABASE_SERVICE_ROLE_KEY
#    - ✅ 已将 .env 添加到 .gitignore
